# IronCore Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3000

# JWT Secret (change this to any random long string)
JWT_SECRET=ironcore_super_secret_key_change_this_2025

# Anthropic API Key (for AI support agent)
# Get it from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database (SQLite - no setup needed locally)
DB_PATH=./database/ironcore.db
